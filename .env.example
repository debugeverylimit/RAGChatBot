# Server
PORT=3000

# LLM (Groq)
GROQ_API_KEY=
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant

# Embeddings (local via Transformers.js)
EMBEDDING_MODEL=Xenova/bge-small-en-v1.5

# ChromaDB
CHROMA_HOST=http://localhost:8000

# Daily ingestion schedule (Phase 7)
INGESTION_SCHEDULE_HOUR=10
INGESTION_SCHEDULE_MINUTE=0
INGESTION_SCHEDULE_TIMEZONE=Asia/Kolkata
