{
  "name": "rag-chatbot",
  "version": "0.1.0",
  "description": "Facts-only mutual fund FAQ assistant (RAG)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc",
    "start": "node dist/app/server.js",
    "ingest": "tsx src/ingestion/run.ts",
    "ingest:index": "tsx src/ingestion/run.ts --index-only",
    "schedule": "tsx src/scheduler/daily.ts --daemon",
    "schedule:once": "tsx src/scheduler/daily.ts --once",
    "retrieve:test": "tsx src/app/retrieve-test.ts",
    "qa:matrix": "tsx src/qa/runEvaluationMatrix.ts",
    "chroma:server": ".venv-chroma/bin/chroma run --path data/index/chroma --port 8000",
    "chroma:setup": "python3 -m venv .venv-chroma && .venv-chroma/bin/pip install chromadb",
    "test": "vitest run"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@xenova/transformers": "^2.0.1",
    "cheerio": "^1.2.0",
    "chromadb": "^3.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.3.0",
    "js-yaml": "^5.1.0",
    "node-cron": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}